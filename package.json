{
  "name": "cargo-figma-replica",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "High-fidelity pixel-perfect replica of the CARGO Car Booking & Sharing App from Figma design system. Built as a modern PWA with React 19, Vite, Tailwind v4.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome lint . --write || echo 'biome not fully configured'",
    "format": "biome format . --write || prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "prepare": "echo 'Ready for development'"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "framer-motion": "^12.4.0",
    "lucide-react": "^0.479.0",
    "maplibre-gl": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.2.0",
    "sonner": "^2.0.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@hookform/resolvers": "^4.1.2",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/vite": "^4.0.9",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "playwright": "^1.50.1",
    "tailwindcss": "^4.0.9",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
