+    opacity: 1,
+    scale: 1,
+  },
+  exit: (direction: number) => ({
+    x: direction > 0 ? -52 : direction < 0 ? 52 : 0,
+    opacity: 0,
+    scale: 0.982,
+  }),
+};
+
+const screenTransition = {
+  type: 'spring' as const,
+  stiffness: 310,
+  damping: 28,
+  mass: 0.85,
+  opacity: { duration: 0.22, ease: [0.23, 1, 0.32, 1] },
+  scale: { duration: 0.18, ease: [0.23, 1, 0.32, 1] },
+};
+
+// Helper to determine slide direction for route changes (forward = +1, back = -1)
+function computeDirection(prevPath: string, nextPath: string): number {
+  const getRank = (p: string): number => {
+    if (p.startsWith('/home')) return 10;
+    if (p.startsWith('/destination')) return 11;
+    if (p.startsWith('/favorites')) return 12;
+    if (p.startsWith('/activity')) return 13;
+    if (p.startsWith('/profile')) return 14;
+    if (p.startsWith('/add-place')) return 15;
+    if (p === '/service') return 20;
+    if (p === '/payment') return 21;
+    if (p.startsWith('/verify')) return 2;
+    if (p.startsWith('/location')) return 3;
+    if (p === '/login' || p === '/signup') return 1;
+    if (p === '/' || p === '/splash') return 0;
+    return 5;
+  };
+  const d = getRank(nextPath) - getRank(prevPath);
+  if (d === 0) return 0;
+  return d > 0 ? 1 : -1;
+}
