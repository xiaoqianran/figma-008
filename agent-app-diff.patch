+// Reusable premium animated page wrapper (direction aware via custom prop from AnimatePresence)
+function AnimatedPage({
+  children,
+  className = '',
+  withTabs = false,
+}: {
+  children: React.ReactNode;
+  className?: string;
+  withTabs?: boolean;
+}) {
+  const location = useLocation();
+  const direction = useDirection(location.pathname);
+
+  return (
+    <motion.div
+      key={location.pathname}
+      custom={direction}
+      variants={screenVariants}
+      initial="enter"
+      animate="center"
+      exit="exit"
+      transition={screenTransition}
+      className={`screen overflow-hidden bg-[#F8F9FA] ${className}`}
+    >
+      {children}
+      {withTabs && <MainTabBar />}
+    </motion.div>
+  );
+}
+
+// Direction hook (must be called inside component tree that has location context)
+function useDirection(currentPath: string) {
+  const prevRef = useRef(currentPath);
+  const [dir, setDir] = useState(0);
+
+  useEffect(() => {
+    const prev = prevRef.current;
+    if (prev !== currentPath) {
+      const computed = computeDirection(prev, currentPath);
+      setDir(computed);
+      prevRef.current = currentPath;
+    }
+  }, [currentPath]);
+
+  return dir;
+}
